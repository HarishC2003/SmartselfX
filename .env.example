# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/smartshelfx
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=yourpassword
USE_MONGO_TRANSACTIONS=false

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="SmartShelfX <your@gmail.com>"

# Client
CLIENT_URL=http://localhost:5173

# Forecast Service
FORECAST_SERVICE_URL=http://localhost:8000

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Cron
WEEKLY_REPORT_CRON=0 8 * * 1
REPORT_TIMEZONE=Asia/Kolkata
